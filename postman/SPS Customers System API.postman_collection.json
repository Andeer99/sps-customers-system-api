  "item": [
    {
      "name": "Local - Consultar clientes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{localBaseUrl}}/customers",
          "host": [
            "{{localBaseUrl}}"
          ],
          "path": [
            "customers"
          ]
        }
      }
    },
    {
      "name": "CloudHub - Consultar clientes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{cloudhubBaseUrl}}/customers",
          "host": [
            "{{cloudhubBaseUrl}}"
          ],
          "path": [
            "customers"
          ]
        }
      }
    },
    {
      "name": "CloudHub - Consultar clientes con Client-ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "client_id",
            "value": "{{clientId}}",
